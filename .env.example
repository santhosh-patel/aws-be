# AWS Cost Analytics MCP Agent — Environment Configuration
# Copy to .env and fill in your values.

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose provider: sarvam (recommended), anthropic, or openai
LLM_PROVIDER=sarvam

# Sarvam AI API Key
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-30b

# Anthropic Claude API Key (optional)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (fallback, optional)
OPENAI_API_KEY=sk-...

# ─── AWS Credentials (Read-Only IAM) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (optional in dev — falls back to local JSON DB)
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/?appName=MyApp

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
ENV=development

# ─── Security (Production) ───────────────────────────────────────────────────
# CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
# TOKEN_TTL_DAYS=7

# ─── Feature Flags ───────────────────────────────────────────────────────────
# LLM_ENABLED=true          # Set to false to disable all LLM calls
# PLANNER_MODE=prompt       # prompt (default) | native_tools (Claude tool-use)
